<?xml version="1.0"?>
<sdf version="1.9">
  <model name="rms_agv">
    <pose>0 0 0.16 0 0 0</pose>

    <link name="base_link">
      <inertial>
        <mass>8.0</mass>
        <inertia>
          <ixx>0.16</ixx>
          <ixy>0</ixy>
          <ixz>0</ixz>
          <iyy>0.22</iyy>
          <iyz>0</iyz>
          <izz>0.28</izz>
        </inertia>
      </inertial>
      <collision name="base_collision">
        <geometry>
          <box>
            <size>0.62 0.42 0.18</size>
          </box>
        </geometry>
      </collision>
      <visual name="base_visual">
        <geometry>
          <box>
            <size>0.62 0.42 0.18</size>
          </box>
        </geometry>
        <material>
          <ambient>0.08 0.18 0.24 1</ambient>
          <diffuse>0.08 0.30 0.42 1</diffuse>
        </material>
      </visual>
      <visual name="sensor_bar">
        <pose>0.22 0 0.13 0 0 0</pose>
        <geometry>
          <box>
            <size>0.12 0.46 0.06</size>
          </box>
        </geometry>
        <material>
          <ambient>0.10 0.75 0.95 1</ambient>
          <diffuse>0.10 0.75 0.95 1</diffuse>
        </material>
      </visual>
    </link>

    <link name="left_wheel">
      <pose>0 0.25 0.02 1.570796 0 0</pose>
      <inertial>
        <mass>0.35</mass>
        <inertia>
          <ixx>0.001</ixx>
          <ixy>0</ixy>
          <ixz>0</ixz>
          <iyy>0.001</iyy>
          <iyz>0</iyz>
          <izz>0.001</izz>
        </inertia>
      </inertial>
      <collision name="collision">
        <geometry>
          <cylinder>
            <radius>0.075</radius>
            <length>0.055</length>
          </cylinder>
        </geometry>
      </collision>
      <visual name="visual">
        <geometry>
          <cylinder>
            <radius>0.075</radius>
            <length>0.055</length>
          </cylinder>
        </geometry>
        <material>
          <ambient>0.02 0.02 0.025 1</ambient>
          <diffuse>0.02 0.02 0.025 1</diffuse>
        </material>
      </visual>
    </link>

    <link name="right_wheel">
      <pose>0 -0.25 0.02 1.570796 0 0</pose>
      <inertial>
        <mass>0.35</mass>
        <inertia>
          <ixx>0.001</ixx>
          <ixy>0</ixy>
          <ixz>0</ixz>
          <iyy>0.001</iyy>
          <iyz>0</iyz>
          <izz>0.001</izz>
        </inertia>
      </inertial>
      <collision name="collision">
        <geometry>
          <cylinder>
            <radius>0.075</radius>
            <length>0.055</length>
          </cylinder>
        </geometry>
      </collision>
      <visual name="visual">
        <geometry>
          <cylinder>
            <radius>0.075</radius>
            <length>0.055</length>
          </cylinder>
        </geometry>
        <material>
          <ambient>0.02 0.02 0.025 1</ambient>
          <diffuse>0.02 0.02 0.025 1</diffuse>
        </material>
      </visual>
    </link>

    <joint name="left_wheel_joint" type="revolute">
      <parent>base_link</parent>
      <child>left_wheel</child>
      <axis>
        <xyz>0 0 1</xyz>
        <limit>
          <lower>-1e16</lower>
          <upper>1e16</upper>
        </limit>
      </axis>
    </joint>

    <joint name="right_wheel_joint" type="revolute">
      <parent>base_link</parent>
      <child>right_wheel</child>
      <axis>
        <xyz>0 0 1</xyz>
        <limit>
          <lower>-1e16</lower>
          <upper>1e16</upper>
        </limit>
      </axis>
    </joint>

    <plugin filename="gz-sim-diff-drive-system" name="gz::sim::systems::DiffDrive">
      <left_joint>left_wheel_joint</left_joint>
      <right_joint>right_wheel_joint</right_joint>
      <wheel_separation>0.50</wheel_separation>
      <wheel_radius>0.075</wheel_radius>
      <odom_publish_frequency>30</odom_publish_frequency>
      <max_linear_acceleration>0.8</max_linear_acceleration>
      <min_linear_acceleration>-0.8</min_linear_acceleration>
      <max_angular_acceleration>1.8</max_angular_acceleration>
      <min_angular_acceleration>-1.8</min_angular_acceleration>
    </plugin>
  </model>
</sdf>
